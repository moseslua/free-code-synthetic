#!/usr/bin/env bash
# free-code wrapper for synthetic.new with Kimi-K2.5-NVFP4
# https://github.com/moseslua/free-code-synthetic

set -e

CONFIG_DIR="${HOME}/.config/free-code"
CONFIG_FILE="${CONFIG_DIR}/config"

# Create config dir if missing
if [ ! -d "$CONFIG_DIR" ]; then
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
fi

# Source config file if exists
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi

# Check for API key in priority order
API_KEY="${ANTHROPIC_AUTH_TOKEN:-${ANTHROPIC_API_KEY:-${SYNTHETIC_API_KEY:-}}}"

# If no API key found, prompt user
if [ -z "$API_KEY" ]; then
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  free-code - First-time setup                              ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║  Enter your synthetic.new API key to save it.              ║"
    echo "║  Get your key from: https://synthetic.new                  ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    printf "API Key: "
    read -r API_KEY
    echo ""

    if [ -z "$API_KEY" ]; then
        echo "Error: API key is required"
        exit 1
    fi

    # Save to config file
    cat > "$CONFIG_FILE" << EOF
# free-code credentials configuration
# This file is sourced by the free-code wrapper script
# Get your key from: https://synthetic.new

SYNTHETIC_API_KEY="${API_KEY}"
EOF
    chmod 600 "$CONFIG_FILE"
    echo "✓ API key saved to ${CONFIG_FILE}"
    echo ""
fi

# Export environment variables
export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-${API_KEY}}"
export ANTHROPIC_API_KEY="${ANTHROPIC_AUTH_TOKEN}"

# API endpoint - note: /anthropic NOT /openai/v1
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-https://api.synthetic.new/anthropic}"

# Model configuration for synthetic.new
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-hf:nvidia/Kimi-K2.5-NVFP4}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-hf:nvidia/Kimi-K2.5-NVFP4}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-hf:zai-org/GLM-4.7-Flash}"
export CLAUDE_CODE_SUBAGENT_MODEL="${CLAUDE_CODE_SUBAGENT_MODEL:-hf:nvidia/Kimi-K2.5-NVFP4}"

# Privacy - disable telemetry
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"

CLAUDE_CODE_CLI="${CLAUDE_CODE_CLI:-$(command -v claude 2>/dev/null || echo "$HOME/.hermes/node/lib/node_modules/@anthropic-ai/claude-code/cli.js")}"

if [ ! -f "$CLAUDE_CODE_CLI" ]; then
    echo "Error: Claude Code not found"
    echo "Install with: npm install -g @anthropic-ai/claude-code"
    exit 1
fi

# Execute claude with all arguments passed through
exec "$CLAUDE_CODE_CLI" "$@"
